@using Microsoft.AspNetCore.Identity
@inject UserManager<Entity.Concrete.AppUser> UserManager

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IT Ticket System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            /* GENEL AYAR: Boş alanlarda imleç standart ok kalsın */
            cursor: default;
        }

        /* Tıklanabilir alanlarda metin seçme imlecini kapatıp el ikonunu zorluyoruz */
        a, button, .btn, .nav-link, .dashboard-card, .user-icon-circle,
        .badge-modern, .sidebar-footer-action, [role="button"] {
            cursor: pointer !important;
            user-select: none !important; /* Metin seçilmesini engeller */
            -webkit-user-select: none; /* Safari desteği */
        }

        /* Sadece veri girişi yapılacak yerlerde yazma imleci çıksın */
        input, textarea, .form-control {
            cursor: text !important;
        }

        .wrapper {
            display: flex;
            align-items: stretch;
            min-height: 100vh;
        }

        /* Sidebar Gelişmiş Yapı */
        #sidebar {
            min-width: 250px;
            max-width: 250px;
            background: #1a1d20;
            color: #fff;
            position: fixed;
            height: 100vh;
            z-index: 999;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
        }

        #content {
            width: 100%;
            margin-left: 250px;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        main {
            flex: 1;
            padding: 30px;
            background-color: #f4f7f6;
        }

        /* Sidebar Linkleri */
        #sidebar .nav-link {
            color: #adb5bd !important;
            padding: 15px 25px;
            display: block;
            width: 100%;
            border-left: 5px solid transparent;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

            #sidebar .nav-link:hover {
                background: #2b3035;
                color: #0dcaf0 !important;
                border-left: 5px solid #0dcaf0;
                padding-left: 35px;
            }

            #sidebar .nav-link.active {
                background: #0d6efd;
                color: #fff !important;
                border-left: 5px solid #fff;
                box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            }

        /* Çıkış Butonu Özel Stili */
        .nav-link-logout {
            border-top: 1px solid #2b3035;
            color: #fa5252 !important;
            font-weight: 600;
        }

            .nav-link-logout:hover {
                background: #c92a2a !important;
                color: #fff !important;
                border-left: 5px solid #fff !important;
                padding-left: 35px;
            }

        .sidebar-user-header {
            padding: 30px 20px;
            background: #111416;
            border-bottom: 1px solid #2b3035;
            display: flex;
            align-items: center;
        }

        .user-icon-circle {
            width: 50px;
            height: 50px;
            background-color: #212529;
            border: 2px solid #0dcaf0;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        /* Footer */
        footer {
            background: #1a1d20;
            border-top: 1px solid #2b3035;
            padding: 25px 0 !important;
            transition: background 0.5s ease;
        }

            footer:hover {
                background: #111416;
            }

        .footer-link {
            transition: color 0.3s ease;
            text-decoration: none;
            color: #6c757d !important;
        }

            .footer-link:hover {
                color: #0dcaf0 !important;
            }
    </style>
</head>
<body>

    @{
        var user = await UserManager.GetUserAsync(User);
        var roles = user != null ? await UserManager.GetRolesAsync(user) : new List<string>();
        var userFullName = user != null ? $"{user.FirstName} {user.LastName}" : "Misafir Kullanıcı";
        var userRole = roles.Contains("Admin") ? "Sistem Yöneticisi" : "Kullanıcı";
    }

    <div class="wrapper">
        <nav id="sidebar">
            <div class="flex-grow-1">
                <div class="sidebar-user-header">
                    <div class="user-icon-circle">
                        <i class="bi bi-person-fill text-info" style="font-size: 1.5rem;"></i>
                        <span class="position-absolute bottom-0 end-0 p-1 bg-success border border-white rounded-circle"></span>
                    </div>
                    <div class="ms-3 overflow-hidden">
                        <h6 class="mb-0 text-white small fw-bold text-truncate" title="@userFullName">@userFullName</h6>
                        <span class="text-info d-block" style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1px; font-weight: 600;">@userRole</span>
                    </div>
                </div>

                <ul class="list-unstyled components mt-3">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")"
                           asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door me-2"></i> Ana Sayfa
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Category" ? "active" : "")"
                           asp-controller="Category" asp-action="Index">
                            <i class="bi bi-grid me-2"></i> Kategoriler
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Ticket" ? "active" : "")"
                           asp-controller="Ticket" asp-action="Index">
                            <i class="bi bi-ticket-detailed me-2"></i> Destek Talepleri
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Calendar" ? "active" : "")"
                           asp-controller="Calendar" asp-action="Index">
                            <i class="bi bi-calendar3 me-2"></i> Ajanda & Takvim
                        </a>
                    </li>
                </ul>
            </div>

            <div class="sidebar-footer-action">
                <form id="logoutForm" asp-controller="Account" asp-action="Logout" method="post" class="d-none"></form>
                <a class="nav-link nav-link-logout" href="javascript:void(0)" onclick="document.getElementById('logoutForm').submit();">
                    <i class="bi bi-box-arrow-right me-2"></i> Çıkış
                </a>
            </div>
        </nav>

        <div id="content">
            <main role="main">
                @RenderBody()
            </main>

            <footer class="mt-auto">
                <div class="container-fluid px-5">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-secondary fw-bold text-uppercase small" style="letter-spacing: 2px;">
                                © 2026 IT DESTEK SİSTEMİ
                            </span>
                        </div>
                        <div class="small">
                            <a href="#" class="footer-link me-4">GİZLİLİK POLİTİKASI</a>
                            <a href="#" class="footer-link me-4">YARDIM MERKEZİ</a>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>