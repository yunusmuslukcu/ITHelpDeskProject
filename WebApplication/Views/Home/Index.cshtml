@using Dto.TicketDtos
@model List<TicketListDto>

@{
    ViewData["Title"] = "Ana Sayfa";
}

<style>
    /* Kartların Boyutunu Küçülttük ve Zarifleştirdik */
    .dashboard-card {
        transition: all 0.3s ease-in-out;
        cursor: pointer;
        border-top: 12px solid #191c24 !important; /* Sidebar ile uyumlu */
        min-height: 150px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

        .dashboard-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.1) !important;
            border-top: 12px solid #00bcd4 !important;
        }

    .stat-value {
        font-size: 2.8rem;
        font-weight: 800;
        color: #191c24;
        line-height: 1;
    }

    .stat-label {
        font-size: 0.9rem;
        letter-spacing: 1.2px;
        color: #6c757d;
        font-weight: 700;
        text-transform: uppercase;
    }

    /* Dashboard Tablo Stilleri */
    .badge-modern {
        padding: 0.4em 0.7em;
        border-radius: 50rem;
        font-weight: 600;
        font-size: 0.7rem;
    }
</style>

<div class="container-fluid pt-4 px-4">
    <div class="row g-4 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="bg-white rounded shadow-sm p-3 dashboard-card">
                <p class="stat-label mb-1">TOPLAM TALEP</p>
                <div class="stat-value">@ViewBag.TotalTickets</div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="bg-white rounded shadow-sm p-3 dashboard-card">
                <p class="stat-label mb-1">AKTİF TALEPLER</p>
                <div class="stat-value">@ViewBag.ActiveTickets</div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="bg-white rounded shadow-sm p-3 dashboard-card">
                <p class="stat-label mb-1">ÇÖZÜLEN TALEPLER</p>
                <div class="stat-value">@ViewBag.SolvedTickets</div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="bg-white rounded shadow-sm p-3 dashboard-card">
                <p class="stat-label mb-1">KATEGORİLER</p>
                <div class="stat-value">@ViewBag.TotalCategories</div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded shadow-sm overflow-hidden">
        <div class="d-flex align-items-center justify-content-between p-3" style="background-color: #191c24;">
            <h6 class="mb-0 text-white fw-bold"><i class="bi bi-clock-history me-2 text-info"></i> SON AKTİF TALEPLER</h6>
            <a href="/Ticket/Index" class="btn btn-sm btn-info text-white fw-bold shadow-sm">Tümünü Gör</a>
        </div>
        <div class="p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    @if (Model != null && Model.Any())
                    {
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4 text-muted small fw-bold">BAŞLIK</th>
                                <th class="small text-muted fw-bold">ÖNCELİK</th>
                                <th class="small text-muted fw-bold">DURUM</th>
                                <th class="text-end pe-4 small text-muted fw-bold">TARİH</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-dark">@item.Title</td>
                                    <td>
                                        <span class="badge-modern @(item.Priority == "Yüksek" ? "bg-danger text-white" : item.Priority == "Orta" ? "bg-warning text-dark" : "bg-info text-white")">
                                            @item.Priority
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge-modern @(item.Status == "Çözüldü" ? "bg-success text-white" : "bg-secondary text-white")">
                                            @item.Status
                                        </span>
                                    </td>
                                    <td class="text-end pe-4 small text-muted font-monospace">@item.CreatedDate.ToString("dd.MM.yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    }
                    else
                    {
                        <tbody>
                            <tr>
                                <td colspan="4" class="py-5 text-center">
                                    <i class="bi bi-info-circle text-muted mb-2 d-block" style="font-size: 2rem;"></i>
                                    <p class="text-muted small mb-0">Henüz yeni bir talep bulunmuyor. Sistem aktif.</p>
                                </td>
                            </tr>
                        </tbody>
                    }
                </table>
            </div>
        </div>
    </div>
</div>