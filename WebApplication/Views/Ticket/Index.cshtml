@using Dto.TicketDtos
@model List<TicketListDto>
@{
    ViewData["Title"] = "Destek Talepleri";
}

<style>
    /* Kategori modülüyle %100 uyumlu Yeni Talep Butonu */
    .btn-custom-cyan {
        background-color: #0dcaf0 !important;
        color: #fff !important;
        font-weight: 700;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        transition: all 0.3s ease;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        display: inline-flex;
        align-items: center;
        text-decoration: none !important;
    }

        .btn-custom-cyan:hover {
            background-color: #0bb5d8 !important;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(13, 202, 240, 0.4);
            color: #fff !important;
        }

    /* Tablo Aksiyon Butonları */
    .btn-action {
        padding: 6px 12px;
        border-radius: 6px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: inline-flex;
        align-items: center;
        text-decoration: none !important;
        cursor: pointer;
        border: none;
    }

    .btn-action-edit:hover {
        background-color: #ffc107 !important;
        color: #000 !important;
        box-shadow: 0 4px 8px rgba(255, 193, 7, 0.3);
        transform: translateY(-2px);
    }

    .btn-action-delete:hover {
        background-color: #dc3545 !important;
        color: #fff !important;
        box-shadow: 0 4px 8px rgba(220, 53, 69, 0.3);
        transform: translateY(-2px);
    }

    /* Badge'leri daha modern ve yuvarlak yapalım */
    .badge-modern {
        padding: 0.5em 0.8em;
        border-radius: 50rem;
        font-weight: 600;
        font-size: 0.75rem;
    }

    /* Kategori Badge Stili */
    .badge-category {
        background-color: #e9ecef;
        color: #495057;
        border: 1px solid #dee2e6;
    }

    /* Açıklama metni için kısıtlama */
    .text-description-truncate {
        display: block;
        max-width: 350px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-size: 0.75rem;
        color: #6c757d;
        margin-top: 2px;
    }
</style>

<div class="container-fluid pt-4 px-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark py-3 d-flex justify-content-between align-items-center">
            <span class="text-secondary fw-bolder text-uppercase" style="letter-spacing: 1.5px; font-size: 0.9rem;">
                <i class="bi bi-ticket-perforated-fill me-2 text-info"></i> AKTİF TALEPLER
            </span>
            <a href="/Ticket/AddTicket" class="btn btn-custom-cyan">
                <i class="bi bi-plus-lg me-1"></i> Yeni Talep Oluştur
            </a>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 text-muted small fw-bold" style="width: 70px;">#NO</th>
                            <th class="small text-muted fw-bold">TALEP DETAYI</th>
                            <th class="small text-muted fw-bold">KATEGORİ</th> @* YENİ SÜTUN *@
                            <th class="small text-muted fw-bold">ÖNCELİK</th>
                            <th class="small text-muted fw-bold">DURUM</th>
                            <th class="small text-muted fw-bold">TARİH</th>
                            <th class="text-center small text-muted fw-bold" style="width: 220px;">İŞLEMLER</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 text-muted font-monospace small">@item.Id</td>
                                    <td>
                                        <div class="fw-bold text-dark">@item.Title</div>
                                        <div class="text-description-truncate" title="@item.Description">
                                            @item.Description
                                        </div>
                                    </td>
                                    <td>
                                        @* Kategori Adı Buraya Geliyor *@
                                        <span class="badge badge-modern badge-category">
                                            <i class="bi bi-tag-fill me-1 text-info"></i> @item.CategoryName
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge-modern @(item.Priority == "Yüksek" ? "bg-danger text-white" : item.Priority == "Orta" ? "bg-warning text-dark" : "bg-info text-white")">
                                            <i class="bi bi-exclamation-circle me-1"></i> @item.Priority
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge-modern @(item.Status == "Çözüldü" ? "bg-success text-white" : "bg-secondary text-white")">
                                            @(item.Status == "Çözüldü" ? "✓ " : "● ") @item.Status
                                        </span>
                                    </td>
                                    <td><span class="text-secondary small">@item.CreatedDate.ToString("dd.MM.yyyy")</span></td>
                                    <td class="text-center">
                                        <a href="/Ticket/UpdateTicket/@item.Id" class="btn-action btn-action-edit text-warning small me-2" title="Detay/Güncelle">
                                            <i class="bi bi-pencil-square me-1"></i> Düzenle
                                        </a>
                                        <button type="button" class="btn-action btn-action-delete text-danger small bg-transparent" onclick="confirmDelete(@item.Id, '@item.Title')" title="Sil">
                                            <i class="bi bi-trash-fill me-1"></i> Sil
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted small">
                                    <i class="bi bi-info-circle me-1"></i> Henüz aktif destek talebi bulunmuyor.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white py-3 border-top-0">
            <small class="text-muted fw-bold">
                <i class="bi bi-info-circle me-1"></i> Toplam <span class="text-dark">@(Model?.Count ?? 0)</span> destek talebi listeleniyor.
            </small>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function confirmDelete(id, title) {
            Swal.fire({
                title: 'Emin misin?',
                text: "['" + title + "'] başlıklı talebi silmek üzeresiniz. Bu işlem geri alınamaz!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Evet, sil!',
                cancelButtonText: 'Vazgeç',
                background: '#fff',
                customClass: {
                    title: 'fw-bold',
                    popup: 'shadow-lg border-0'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = "/Ticket/DeleteTicket/" + id;
                }
            })
        }
    </script>
}