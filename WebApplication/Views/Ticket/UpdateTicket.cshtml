@using Dto.TicketDtos
@model TicketUpdateDto
@{
    ViewData["Title"] = "Talep Güncelle";
}

<div class="container-fluid pt-4 px-4">
    @* Sayfa Başlığı - Merkezi Hizalama *@
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            @* Ana Kart Yapısı *@
            <div class="card shadow-sm border-0 mb-3">
                @* Header: Sistem geneliyle tam uyumlu *@
                <div class="card-header bg-dark py-3">
                    <span class="text-secondary fw-bolder text-uppercase" style="letter-spacing: 1.5px; font-size: 0.9rem;">
                        <i class="bi bi-pencil-square me-2 text-info"></i> TALEP NO: @Model.Id
                    </span>
                </div>

                <div class="card-body p-4 bg-white">
                    <form method="post">
                        @* ID alanını gizli gönderiyoruz *@
                        @Html.HiddenFor(x => x.Id)

                        <div class="row">
                            @* Başlık *@
                            <div class="col-md-12 mb-4">
                                <label asp-for="Title" class="form-label fw-bold text-muted small text-uppercase">Talep Başlığı</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-secondary">
                                        <i class="bi bi-type-h1"></i>
                                    </span>
                                    <input type="text" asp-for="Title" class="form-control border-start-0 ps-0 shadow-none" required />
                                </div>
                                <span asp-validation-for="Title" class="text-danger small"></span>
                            </div>

                            @* Kategori ve Tarih (Veya başka bir alan) Yan Yana *@
                            <div class="col-md-12 mb-4">
                                <label class="form-label fw-bold text-muted small text-uppercase">Kategori</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-secondary">
                                        <i class="bi bi-grid-fill"></i>
                                    </span>
                                    @Html.DropDownListFor(x => x.CategoryId, (List<SelectListItem>)ViewBag.CategoryList,
                                    new { @class = "form-select border-start-0 ps-0 shadow-none" })
                                </div>
                            </div>

                            @* Öncelik ve Durum Yan Yana *@
                            <div class="col-md-6 mb-4">
                                <label asp-for="Priority" class="form-label fw-bold text-muted small text-uppercase">Öncelik Seviyesi</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-secondary">
                                        <i class="bi bi-exclamation-triangle-fill"></i>
                                    </span>
                                    <select asp-for="Priority" class="form-select border-start-0 ps-0 shadow-none">
                                        <option value="Düşük">Düşük</option>
                                        <option value="Orta">Orta</option>
                                        <option value="Yüksek">Yüksek</option>
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="Status" class="form-label fw-bold text-muted small text-uppercase">Güncel Durum</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-secondary">
                                        <i class="bi bi-info-circle-fill"></i>
                                    </span>
                                    <select asp-for="Status" class="form-select border-start-0 ps-0 shadow-none">
                                        <option value="Açık">Açık</option>
                                        <option value="İşlemde">İşlemde</option>
                                        <option value="Çözüldü">Çözüldü</option>
                                        <option value="İptal Edildi">İptal Edildi</option>
                                    </select>
                                </div>
                            </div>

                            @* Açıklama *@
                            <div class="col-md-12 mb-4">
                                <label asp-for="Description" class="form-label fw-bold text-muted small text-uppercase">Talep Açıklaması</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-secondary align-items-start pt-2">
                                        <i class="bi bi-card-text"></i>
                                    </span>
                                    <textarea asp-for="Description" class="form-control border-start-0 ps-0 shadow-none" rows="5"></textarea>
                                </div>
                            </div>
                        </div>

                        <hr class="text-muted opacity-25">

                        @* Butonlar *@
                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a href="/Ticket/Index" class="btn btn-outline-secondary fw-bold px-4 border-2">
                                <i class="bi bi-x-lg me-1"></i> İptal
                            </a>
                            <button type="submit" class="btn btn-info fw-bold px-5 shadow-sm text-dark">
                                <i class="bi bi-check-lg me-1"></i> Değişiklikleri Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @* Mühendis Notu (Mavi Alert) *@
            <div class="alert alert-info border-0 shadow-sm p-3 d-flex align-items-center">
                <i class="bi bi-info-circle-fill fs-4 me-3"></i>
                <div class="small">
                    <strong>Bilgilendirme:</strong> Talebin durumunu "Çözüldü" olarak işaretlediğinizde, kullanıcıya otomatik bildirim gidecektir. Lütfen açıklama kısmına yapılan işlemle ilgili kısa bir not eklemeyi unutmayın.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}