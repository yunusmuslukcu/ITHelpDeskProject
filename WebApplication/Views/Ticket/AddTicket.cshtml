@using Dto.TicketDtos
@model TicketCreateDto
@{
    ViewData["Title"] = "Yeni Destek Talebi";
}

<div class="container-fluid pt-4 px-4">
    @* Sayfa Başlığı - Merkezi Hizalama *@
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            @* Ana Kart Yapısı *@
            <div class="card shadow-sm border-0 mb-3">
                @* Header *@
                <div class="card-header bg-dark py-3">
                    <span class="text-secondary fw-bolder text-uppercase" style="letter-spacing: 1.5px; font-size: 0.9rem;">
                        <i class="bi bi- megaphone-fill me-2 text-info"></i> TALEP DETAYLARI
                    </span>
                </div>

                <div class="card-body p-4 bg-white">
                    <form method="post">
                        <input type="hidden" asp-for="AppUserId" value="1" /> @* Geçici ID *@

                        <div class="row">
                            @* Başlık *@
                            <div class="col-md-12 mb-4">
                                <label asp-for="Title" class="form-label fw-bold text-muted small text-uppercase">Talep Başlığı</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-secondary">
                                        <i class="bi bi-type-h1"></i>
                                    </span>
                                    <input type="text" asp-for="Title" class="form-control border-start-0 ps-0 shadow-none"
                                           placeholder="Sorunu kısaca özetleyin..." required />
                                </div>
                                <span asp-validation-for="Title" class="text-danger small"></span>
                            </div>

                            @* Kategori ve Öncelik Yan Yana *@
                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-bold text-muted small text-uppercase">Kategori</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-secondary">
                                        <i class="bi bi-grid-fill"></i>
                                    </span>
                                    @Html.DropDownListFor(x => x.CategoryId, (List<SelectListItem>)ViewBag.CategoryList, "Kategori Seçiniz",
                                    new { @class = "form-select border-start-0 ps-0 shadow-none", required = "required" })
                                </div>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="Priority" class="form-label fw-bold text-muted small text-uppercase">Öncelik Seviyesi</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-secondary">
                                        <i class="bi bi-exclamation-triangle-fill"></i>
                                    </span>
                                    <select asp-for="Priority" class="form-select border-start-0 ps-0 shadow-none">
                                        <option value="Düşük">Düşük</option>
                                        <option value="Orta">Orta</option>
                                        <option value="Yüksek">Yüksek</option>
                                    </select>
                                </div>
                            </div>

                            @* Açıklama *@
                            <div class="col-md-12 mb-4">
                                <label asp-for="Description" class="form-label fw-bold text-muted small text-uppercase">Detaylı Açıklama</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-secondary align-items-start pt-2">
                                        <i class="bi bi-card-text"></i>
                                    </span>
                                    <textarea asp-for="Description" class="form-control border-start-0 ps-0 shadow-none"
                                              rows="5" placeholder="Yaşadığınız sorunu detaylıca anlatın..."></textarea>
                                </div>
                            </div>
                        </div>

                        <hr class="text-muted opacity-25">

                        @* Butonlar *@
                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a href="/Ticket/Index" class="btn btn-outline-secondary fw-bold px-4 border-2">
                                <i class="bi bi-arrow-left me-1"></i> Listeye Dön
                            </a>
                            <button type="submit" class="btn btn-info fw-bold px-5 shadow-sm text-dark">
                                <i class="bi bi-send-fill me-1"></i> Talebi Gönder
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @* Mühendis Notu / İpucu *@
            <div class="alert alert-info border-0 shadow-sm p-3 d-flex align-items-center">
                <i class="bi bi-shield-lock-fill fs-4 me-3"></i>
                <div class="small">
                    <strong>İpucu:</strong> Talebinizi ne kadar detaylı açıklarsanız, çözüm süreci o kadar hızlanacaktır. Varsa hata kodlarını mutlaka ekleyin.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}