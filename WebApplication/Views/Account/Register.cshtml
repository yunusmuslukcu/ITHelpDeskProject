@model Dto.UserDtos.UserRegisterDto

@{
    Layout = null; // Login ile aynı bağımsız stilde olması için
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kayıt Ol | IT Destek</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #1a1a1a;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
        }

        .register-card {
            background-color: #252525;
            padding: 2rem;
            border-radius: 8px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
            width: 100%;
            max-width: 500px;
        }

        .btn-it-destek {
            background-color: #00bcd4;
            color: black;
            font-weight: bold;
            border: none;
        }

            .btn-it-destek:hover {
                background-color: #00acc1;
                color: white;
            }

        .form-control {
            background-color: #2b2b2b !important;
            color: white !important;
            border: 1px solid #444 !important;
        }

            .form-control:focus {
                border-color: #00bcd4 !important;
                box-shadow: none !important;
            }
    </style>
</head>
<body>

    <div class="register-card">
        <div class="text-center mb-4">
            <h4 class="text-info">YENİ HESAP OLUŞTUR</h4>
            <p class="text-muted small">IT Destek ekibine katılmak için bilgileri doldurun</p>
        </div>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="FirstName" class="form-label small">Adınız</label>
                    <input asp-for="FirstName" class="form-control form-control-sm" placeholder="Adınız..." />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="LastName" class="form-label small">Soyadınız</label>
                    <input asp-for="LastName" class="form-control form-control-sm" placeholder="Soyadınız..." />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="UserName" class="form-label small">Kullanıcı Adı</label>
                <input asp-for="UserName" class="form-control form-control-sm" placeholder="Kullanıcı Adınız..." />
                <span asp-validation-for="UserName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label small">E-Posta Adresi</label>
                <input asp-for="Email" type="email" class="form-control form-control-sm" placeholder="ornek@itdestek.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Password" class="form-label small">Şifre</label>
                    <input asp-for="Password" type="password" class="form-control form-control-sm" placeholder="********" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="ConfirmPassword" class="form-label small">Şifre Tekrar</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control form-control-sm" placeholder="********" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-it-destek w-100 mb-3">KAYIT OL</button>

            <div class="text-center">
                <p class="small text-muted">Zaten hesabın var mı? <a asp-action="Login" class="text-info text-decoration-none">Giriş Yap</a></p>
            </div>
        </form>
    </div>

</body>
</html>